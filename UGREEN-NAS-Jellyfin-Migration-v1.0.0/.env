# ============================================================
# UGREEN NAS Jellyfin Migration v1.0.0
# ============================================================
# DE: Diese Datei muss normalerweise NICHT bearbeitet werden.
#     Die Standardwerte sind fuer die normale Migration vorbereitet.
#     Nur erfahrene Benutzer sollten hier Anpassungen vornehmen.
# EN: This file normally does NOT need to be edited.
#     The defaults are prepared for the normal migration.
#     Only experienced users should change these values.
# ============================================================

# DE: Sprache fuer Script-Ausgaben. Erlaubt: de oder en.
# EN: Language for script output. Allowed: de or en.
LANGUAGE=de

# DE: Migrationsmodus.
#     CHECK_ONLY     = nur pruefen, nichts aendern
#     BACKUP_ONLY    = nur Backup erstellen, alte App bleibt aktiv
#     SAFE_MIGRATION = empfohlen: Backup, Migration, alte App stoppen, neuen Container starten
#     FULL_MIGRATION = erweitert: wie SAFE_MIGRATION, danach optional alte Container entfernen
# EN: Migration mode.
#     CHECK_ONLY     = only check, change nothing
#     BACKUP_ONLY    = create backup only, old app keeps running
#     SAFE_MIGRATION = recommended: backup, migrate, stop old app, start new container
#     FULL_MIGRATION = advanced: like SAFE_MIGRATION, then optionally remove old containers
MIGRATION_MODE=SAFE_MIGRATION

# DE: Zielordner fuer das neue Docker-Projekt.
#     auto erkennt /volumeX/docker und nutzt /volumeX/docker/JellyfinDocker.
# EN: Target folder for the new Docker project.
#     auto detects /volumeX/docker and uses /volumeX/docker/JellyfinDocker.
DOCKER_PROJECT_PATH=auto

# DE: Zielordner fuer Migrations-Backups.
#     auto erkennt /volumeX/docker und nutzt /volumeX/docker/Jellyfin-Migration-Backup.
# EN: Target folder for migration backups.
#     auto detects /volumeX/docker and uses /volumeX/docker/Jellyfin-Migration-Backup.
BACKUP_PATH=auto

# DE: Medien-Mount-Modus.
#     rw = kompatibel zur UGREEN-App und erlaubt Jellyfin NFO/Poster neben Medien zu schreiben.
#     ro = restriktiver, Jellyfin kann dann keine Metadaten neben Medien schreiben.
# EN: Media mount mode.
#     rw = compatible with the UGREEN app and allows Jellyfin to write NFO/posters next to media.
#     ro = more restrictive; Jellyfin cannot write metadata next to media.
MEDIA_MOUNT_MODE=rw

# DE: HTTP-Port fuer den neuen Jellyfin-Container.
#     auto uebernimmt den Host-Port der alten UGREEN-Jellyfin-App.
# EN: HTTP port for the new Jellyfin container.
#     auto reuses the host port from the old UGREEN Jellyfin app.
JELLYFIN_PORT_HTTP=auto

# DE: Jellyfin-Image. Standard ist das offizielle Jellyfin-Image.
# EN: Jellyfin image. The default is the official Jellyfin image.
JELLYFIN_IMAGE=jellyfin/jellyfin:latest

# DE: Namen fuer Container, Compose-Projekt und UGOS-Projekt.
#     Diese Namen vermeiden Konflikte mit dem alten UGREEN-Projekt "jellyfin".
# EN: Names for container, Compose project and UGOS project.
#     These names avoid conflicts with the old UGREEN project named "jellyfin".
JELLYFIN_CONTAINER_NAME=jellyfin-docker
COMPOSE_PROJECT_NAME=jellyfin-docker
UGOS_PROJECT_NAME=jellyfin-docker
COMPOSE_FILE_NAME=docker-compose.yaml

# DE: Alte Testmigrationen aus fruehen Versionen erkennen und auf Wunsch umbenennen.
# EN: Detect old test migrations from early versions and offer to rename them.
LEGACY_TEST_PROJECT_CLEANUP=ask

# DE: Wenn bereits eine JellyfinDocker-Testmigration existiert, kann sie fuer einen neuen Test gestoppt und umbenannt werden.
#     Bei interaktiver Nutzung ist die Vorauswahl Ja.
# EN: If an existing JellyfinDocker test migration exists, it can be stopped and renamed for a new test.
#     In interactive mode the default answer is Yes.
EXISTING_TARGET_PROJECT_CLEANUP=ask

# DE: Benutzer/Gruppen fuer den neuen Jellyfin-Container.
#     auto nutzt den sudo-Benutzer oder erkennt UID/GID ueber die Medienpfade.
#     Ziel: Jellyfin laeuft nicht als root.
# EN: User/groups for the new Jellyfin container.
#     auto uses the sudo user or detects UID/GID from the media paths.
#     Goal: Jellyfin does not run as root.
JELLYFIN_USER=auto
JELLYFIN_UID=auto
JELLYFIN_GID=auto
JELLYFIN_GROUPS=auto

# DE: Hardwarebeschleunigung.
#     auto uebernimmt erkannte Geraete wie /dev/dri aus dem alten UGREEN-Container.
# EN: Hardware acceleration.
#     auto reuses detected devices such as /dev/dri from the old UGREEN container.
ENABLE_HARDWARE_ACCEL=auto

# DE: In SAFE_MIGRATION muss die alte App gestoppt werden, damit der neue Container denselben Port nutzen kann.
# EN: In SAFE_MIGRATION the old app must be stopped so the new container can use the same port.
STOP_UGREEN_APP=true

# DE: Konservative Vorgabe: Die alte UGREEN-App wird nicht automatisch entfernt.
#     Nach erfolgreicher Pruefung bitte im UGREEN App Center manuell deinstallieren.
# EN: Conservative default: The old UGREEN app is not removed automatically.
#     After successful verification, uninstall it manually in the UGREEN App Center.
REMOVE_UGREEN_APP=false
I_UNDERSTAND_UGREEN_APP_REMOVAL=false

# DE: Cache wird gesichert, aber der neue Container nutzt standardmaessig einen frischen Cache.
#     /cache/transcodes wird bewusst uebersprungen, weil es temporaere Wiedergabe-/Transcoding-Dateien enthaelt.
# EN: Cache is backed up, but the new container uses a fresh cache by default.
#     /cache/transcodes is intentionally skipped because it contains temporary playback/transcoding files.
CACHE_MIGRATE=false

# DE: UGOS-Projektregistrierung.
#     ask   = empfohlen: interaktiv fragen, Datenbank wird vorher gesichert
#     true  = automatisch registrieren
#     false = UGOS-Docker-DB nicht anfassen
# EN: UGOS project registration.
#     ask   = recommended: ask interactively, DB is backed up before changes
#     true  = register automatically
#     false = do not touch the UGOS Docker DB
UGOS_DOCKER_DB=auto
REGISTER_UGOS_PROJECT=ask
REFRESH_UGOS_DOCKER_APP=ask
UGOS_DOCKER_SERVICE=docker_serv

# DE: Root-eigene Jellyfin/Kodi-Metadaten erkennen und berichten.
#     Wenn der echte Zugriffstest erfolgreich ist, wird nichts automatisch geaendert.
# EN: Detect and report root-owned Jellyfin/Kodi metadata.
#     If the real access test succeeds, nothing is changed automatically.
ROOT_METADATA_SCAN=true
ROOT_METADATA_ACTION=ask
ROOT_METADATA_REPORT_LIMIT=5000
PROTECT_MEDIA_FILES=true

# DE: Interaktive Rueckfragen aktivieren.
# EN: Enable interactive prompts.
INTERACTIVE=true

# DE: Zeitzone fuer den neuen Jellyfin-Container.
# EN: Time zone for the new Jellyfin container.
TZ=Europe/Berlin
